{
  "manifest_version": 3,
  "name": "Test Solver",
  "version": "0.6",
  "description": "Test Solver",
  "author" : "Bartosz Kuba",
  "action": {
    "default_popup": "app.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.testportal.pl/*",
        "*://testportal.pl/*",
        "*://*.testportal.net/*",
        "*://testportal.net/*",
        "*://*.wayground.com/*",
        "*://wayground.com/*",
        "*://*.quizizz.com/*",
        "*://quizizz.com/*"
      ],
      "js": ["anticheat.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.testportal.pl/*",
        "*://testportal.pl/*",
        "*://*.testportal.net/*",
        "*://testportal.net/*",
        "*://*.wayground.com/*",
        "*://wayground.com/*",
        "*://*.quizizz.com/*",
        "*://quizizz.com/*"
      ],
      "js": ["solver.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ]
}